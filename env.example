# Medster-local-LLM Environment Configuration
# Copy this file to .env and update the paths for your system

# =============================================================================
# Model routing (PRIMARY) — single OptiQ VLM on Apple Silicon, NO API KEY
# =============================================================================
# OPTI_ALL_MODE=true  -> the agent loop AND vision run on one on-device model,
#   Qwen3.6-35B-A3B OptiQ 4-bit via mlx_vlm. Ollama is NOT required.
#   Get the model once:  uv run hf download mlx-community/Qwen3.6-35B-A3B-OptiQ-4bit
# OPTI_ALL_MODE=false -> fall back to Ollama for text (OLLAMA_* below apply).
OPTI_ALL_MODE=true

# =============================================================================
# Ollama Configuration (OPTIONAL fallback — only used if OPTI_ALL_MODE=false)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b-mlx

# =============================================================================
# Coherent Data Set Configuration (REQUIRED FOR BETA TESTING)
# =============================================================================
# Download 9GB dataset from: https://synthea.mitre.org/downloads
# File: coherent-11-07-2022.zip
#
# Contains:
#   - 1,278 FHIR patient bundles (longitudinal records)
#   - 298 DICOM brain MRI scans (~9GB)
#   - ECG waveforms in CSV format
#   - Lab results, medications, conditions, procedures
#   - Clinical notes and discharge summaries
#   - Genomic data (889 CSV files)
#
# After extraction, update these paths:
# TIP: Use absolute paths for reliability (e.g., /Users/yourname/Desktop/Medster-local-LLM/coherent_data/fhir)

# Path to FHIR patient bundles (1,278 JSON files)
COHERENT_DATA_PATH=./coherent_data/fhir

# Path to DICOM images (298 brain MRI scans) - Required for vision analysis
COHERENT_DICOM_PATH=./coherent_data/dicom

# Path to CSV files (ECG waveforms and observations) - Required for ECG analysis
COHERENT_CSV_PATH=./coherent_data/csv

# Path to DNA/genomic data (889 CSV files with SNP variants)
COHERENT_DNA_PATH=./coherent_data/dna

# =============================================================================
# MCP Medical Analysis Server (OPTIONAL)
# =============================================================================
# For complex note analysis using Claude API via MCP server
# Only used when user explicitly requests "MCP analysis" or "send to MCP"
MCP_SERVER_URL=http://localhost:8000
MCP_API_KEY=your_api_key_here
MCP_DEBUG=false

# =============================================================================
# Agent Configuration (OPTIONAL - Advanced Users)
# =============================================================================
# Maximum steps before agent stops
MAX_STEPS=20

# Maximum steps per individual task
MAX_STEPS_PER_TASK=5
